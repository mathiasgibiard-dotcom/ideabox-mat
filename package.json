import { useState, useEffect, useRef, useCallback } from "react";

const GLITCH_CHARS = "!<>-_\\/[]{}—=+*^?#@$%&";

const FOLDERS = [
  { id: "libre",    label: "Libre",         icon: "⚡", color: "#00ff88", desc: "L'IA détecte le type" },
  { id: "web",      label: "Site Web",       icon: "🌐", color: "#00aaff", desc: "Landing, vitrine, blog..." },
  { id: "mobile",   label: "App Mobile",     icon: "📱", color: "#bf5fff", desc: "iOS, Android, Flutter..." },
  { id: "logiciel", label: "Logiciel",       icon: "💻", color: "#00ffcc", desc: "Desktop, SaaS, outil..." },
  { id: "saas",     label: "Outils & SaaS",  icon: "⚙️", color: "#ff6600", desc: "Dashboard, API, plateforme..." },
  { id: "gestion",  label: "Gestion & Suivi",icon: "📊", color: "#ffe600", desc: "CRM, tableau de bord, suivi..." },
  { id: "autre",    label: "Autre",          icon: "🔮", color: "#e879f9", desc: "Autre type de projet..." },
];

const STATUS_CONFIG = {
  idée:     { label: "IDÉE",     color: "#00e5ff" },
  en_cours: { label: "EN COURS", color: "#ffe600" },
  terminé:  { label: "TERMINÉ",  color: "#00ff88" },
};
const PRIORITY_CONFIG = {
  haute:   { label: "▲ HAUTE",   color: "#ff4466" },
  moyenne: { label: "► MOYENNE", color: "#ffaa00" },
  basse:   { label: "▼ BASSE",   color: "#556655" },
};

const GLITCH_CHARS_ARR = GLITCH_CHARS.split("");
function GlitchText({ text, active }) {
  const [display, setDisplay] = useState(text);
  useEffect(() => {
    if (!active) { setDisplay(text); return; }
    let iter = 0;
    const iv = setInterval(() => {
      setDisplay(text.split("").map((c, i) => {
        if (i < iter) return text[i];
        if (c === " ") return " ";
        return GLITCH_CHARS_ARR[Math.floor(Math.random() * GLITCH_CHARS_ARR.length)];
      }).join(""));
      if (iter >= text.length) clearInterval(iv);
      iter += 1.5;
    }, 28);
    return () => clearInterval(iv);
  }, [active, text]);
  return <span>{display}</span>;
}

function Corner({ pos }) {
  const top = pos.includes("top"), left = pos.includes("left");
  return <div style={{
    position: "absolute",
    top: top ? 0 : "auto", bottom: top ? "auto" : 0,
    left: left ? 0 : "auto", right: left ? "auto" : 0,
    width: 10, height: 10,
    borderTop: top ? "2px solid #00ff8866" : "none",
    borderBottom: !top ? "2px solid #00ff8866" : "none",
    borderLeft: left ? "2px solid #00ff8866" : "none",
    borderRight: !left ? "2px solid #00ff8866" : "none",
  }}/>;
}

function Logo({ size = 34 }) {
  return (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none">
      <rect width="32" height="32" rx="6" fill="#020e06"/>
      <rect x="0.5" y="0.5" width="31" height="31" rx="5.5" stroke="#00ff8844"/>
      <circle cx="16" cy="13" r="6" stroke="#00ff88" strokeWidth="1.5" fill="none"/>
      <path d="M13 19h6" stroke="#00ff88" strokeWidth="1.5" strokeLinecap="round"/>
      <path d="M13.5 21.5h5" stroke="#00ff8877" strokeWidth="1.2" strokeLinecap="round"/>
      <path d="M14 24h4" stroke="#00ff8844" strokeWidth="1" strokeLinecap="round"/>
      <line x1="16" y1="7" x2="16" y2="5" stroke="#00ff88" strokeWidth="1.2" strokeLinecap="round"/>
      <line x1="11" y1="9" x2="9.5" y2="7.5" stroke="#00ff8866" strokeWidth="1.2" strokeLinecap="round"/>
      <line x1="21" y1="9" x2="22.5" y2="7.5" stroke="#00ff8866" strokeWidth="1.2" strokeLinecap="round"/>
      <circle cx="16" cy="13" r="2" fill="#00ff8822"/>
      <circle cx="16" cy="13" r="1" fill="#00ff8866"/>
    </svg>
  );
}

function buildSystemPrompt(folder) {
  const folderInstructions = {
    libre: "Détecte toi-même le type de projet (site web, app mobile, logiciel, SaaS, gestion...) et adapte ta réponse en conséquence.",
    web: "Ce projet est un SITE WEB. Adapte les fonctionnalités, les technos (HTML/CSS/JS, React, Next.js, WordPress...) et le prompt en conséquence.",
    mobile: "Ce projet est une APPLICATION MOBILE. Adapte les fonctionnalités, les technos (React Native, Flutter, Swift, Kotlin...) et le prompt en conséquence.",
    logiciel: "Ce projet est un LOGICIEL DESKTOP ou SaaS. Adapte les fonctionnalités, les technos (Electron, Python, .NET...) et le prompt en conséquence.",
    saas: "Ce projet est un OUTIL ou SaaS en ligne. Adapte les fonctionnalités, les technos (Node.js, React, API REST, base de données...) et le prompt en conséquence.",
    gestion: "Ce projet est un OUTIL DE GESTION ou TABLEAU DE BORD. Adapte les fonctionnalités (tableaux, filtres, exports, rapports...) et le prompt en conséquence.",
    autre: "Adapte le type de projet selon la description.",
  };
  return `Tu es un expert en développement logiciel et digital. ${folderInstructions[folder] || ""}
L'utilisateur te donne une idée brute de projet. Génère une fiche projet complète ET un prompt professionnel optimisé pour Claude.

Réponds UNIQUEMENT en JSON valide, sans markdown, sans backticks, sans texte autour.
Format exact :
{
  "titre": "Nom court max 3 mots",
  "concept": "Description claire en 1-2 phrases",
  "fonctionnalites": ["fonc 1","fonc 2","fonc 3","fonc 4"],
  "folder": "un parmi : Libre / Site Web / App Mobile / Logiciel / Outils & SaaS / Gestion & Suivi / Autre",
  "status": "idée",
  "priority": "haute ou moyenne ou basse",
  "tags": ["tag1","tag2","tag3"],
  "prompt": "Prompt complet prêt pour Claude : commence par le rôle expert, décris précisément le projet, liste toutes les fonctionnalités, indique les technos recommandées, demande l'architecture complète, le code, la structure base de données et les instructions de déploiement."
}`;
}

export default function IdeaBoxMat() {
  const [screen, setScreen] = useState("home"); // home | input | ideas | idea_detail
  const [selectedFolder, setSelectedFolder] = useState(null);
  const [rawInput, setRawInput] = useState("");
  const [ideas, setIdeas] = useState([]);
  const [isRecording, setIsRecording] = useState(false);
  const [isProcessing, setIsProcessing] = useState(false);
  const [activeIdea, setActiveIdea] = useState(null);
  const [glitchId, setGlitchId] = useState(null);
  const [copiedId, setCopiedId] = useState(null);
  const [deleteConfirm, setDeleteConfirm] = useState(null);
  const [filterFolder, setFilterFolder] = useState("toutes");
  const [filterStatus, setFilterStatus] = useState("tous"); // eslint-disable-line no-unused-vars
  const [searchVal, setSearchVal] = useState("");
  const [syncStatus, setSyncStatus] = useState("idle");
  const [driveLoaded, setDriveLoaded] = useState(false);
  const [toast, setToast] = useState(null);
  const [time, setTime] = useState("");
  const recognitionRef = useRef(null);
  const saveTimerRef = useRef(null);
  const inputRef = useRef(null);

  useEffect(() => {
    const t = setInterval(() => setTime(new Date().toLocaleTimeString("fr-FR")), 1000);
    setTime(new Date().toLocaleTimeString("fr-FR"));
    return () => clearInterval(t);
  }, []);

  useEffect(() => { loadData(); }, []); // eslint-disable-line react-hooks/exhaustive-deps

  useEffect(() => {
    if (screen === "input" && inputRef.current) {
      setTimeout(() => inputRef.current?.focus(), 100);
    }
  }, [screen]);

  const callDrive = useCallback(async (instruction) => {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514", max_tokens: 4096,
        mcp_servers: [{ type: "url", url: "https://drivemcp.googleapis.com/mcp/v1", name: "gdrive" }],
        messages: [{ role: "user", content: instruction }],
      }),
    });
    return await res.json();
  }, []);

  const loadData = async () => {
    setSyncStatus("syncing");
    try {
      const data = await callDrive(`Search Google Drive for a file named exactly "boite-a-idees-mat.json". If found, read and return ONLY its raw JSON content. If not found, return exactly: NOT_FOUND`);
      const toolResults = data.content?.filter(b => b.type === "mcp_tool_result") || [];
      const textBlocks = data.content?.filter(b => b.type === "text").map(b => b.text).join("") || "";
      let jsonStr = "";
      for (const tr of toolResults) {
        const t = tr.content?.[0]?.text || "";
        if (t.includes('"ideas"')) { jsonStr = t; break; }
      }
      if (!jsonStr && textBlocks.includes('"ideas"')) {
        const m = textBlocks.match(/\{[\s\S]*"ideas"[\s\S]*\}/);
        if (m) jsonStr = m[0];
      }
      if (jsonStr) {
        const p = JSON.parse(jsonStr);
        if (p.ideas) setIdeas(p.ideas);
        setSyncStatus("ok"); showToast("Drive chargé ✓");
      } else {
        const local = localStorage.getItem("mat-ideas-v4");
        if (local) { const p = JSON.parse(local); if (p.ideas) setIdeas(p.ideas); }
        setSyncStatus("ok");
      }
    } catch {
      try { const local = localStorage.getItem("mat-ideas-v4"); if (local) { const p = JSON.parse(local); if (p.ideas) setIdeas(p.ideas); } } catch {}
      setSyncStatus("err"); showToast("Drive indisponible — local", "err");
    }
    setDriveLoaded(true);
  };

  const saveToDrive = useCallback((updatedIdeas) => {
    if (!driveLoaded) return;
    if (saveTimerRef.current) clearTimeout(saveTimerRef.current);
    saveTimerRef.current = setTimeout(async () => {
      setSyncStatus("syncing");
      const payload = JSON.stringify({ ideas: updatedIdeas }, null, 2);
      localStorage.setItem("mat-ideas-v4", payload);
      try {
        await callDrive(`Save this JSON to Google Drive. If "boite-a-idees-mat.json" exists, overwrite it. Otherwise create it. Content: ${payload}`);
        setSyncStatus("ok");
      } catch { setSyncStatus("err"); }
    }, 1500);
  }, [driveLoaded, callDrive]);

  const saveIdeas = (u) => { setIdeas(u); saveToDrive(u); };

  const showToast = (msg, type = "ok") => {
    setToast({ msg, type });
    setTimeout(() => setToast(null), 3000);
  };

  const startRecording = () => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { showToast("Vocal non disponible", "err"); return; }
    const r = new SR(); r.lang = "fr-FR"; r.continuous = false; r.interimResults = false;
    r.onresult = e => setRawInput(p => p ? p + " " + e.results[0][0].transcript : e.results[0][0].transcript);
    r.onerror = () => { showToast("Erreur micro", "err"); setIsRecording(false); };
    r.onend = () => setIsRecording(false);
    recognitionRef.current = r; r.start(); setIsRecording(true);
  };
  const stopRecording = () => { recognitionRef.current?.stop(); setIsRecording(false); };

  const generateIdea = async () => {
    if (!rawInput.trim()) return;
    setIsProcessing(true);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514", max_tokens: 1500,
          system: buildSystemPrompt(selectedFolder?.id || "libre"),
          messages: [{ role: "user", content: rawInput }],
        }),
      });
      const data = await res.json();
      const parsed = JSON.parse(data.content?.[0]?.text || "{}");
      const idea = {
        id: Date.now(), raw: rawInput,
        titre: parsed.titre || "Nouvelle idée",
        concept: parsed.concept || "",
        fonctionnalites: parsed.fonctionnalites || [],
        folder: parsed.folder || selectedFolder?.label || "Libre",
        folderColor: selectedFolder?.color || "#00ff88",
        status: "idée",
        priority: parsed.priority || "moyenne",
        tags: parsed.tags || [],
        prompt: parsed.prompt || "",
        date: new Date().toLocaleDateString("fr-FR"),
        ts: Date.now(),
      };
      const updated = [idea, ...ideas];
      saveIdeas(updated);
      setRawInput("");
      setActiveIdea(idea);
      setScreen("idea_detail");
      showToast("Idée générée ✓");
    } catch { showToast("Erreur IA", "err"); }
    setIsProcessing(false);
  };

  const deleteIdea = (id) => {
    saveIdeas(ideas.filter(i => i.id !== id));
    setDeleteConfirm(null);
    setScreen("ideas");
    showToast("Idée supprimée");
  };

  const updateStatus = (id, status) => {
    const updated = ideas.map(i => i.id === id ? { ...i, status } : i);
    saveIdeas(updated);
    setActiveIdea(prev => prev?.id === id ? { ...prev, status } : prev);
  };

  const moveIdea = (id, folder) => {
    const f = FOLDERS.find(x => x.label === folder || x.id === folder);
    const updated = ideas.map(i => i.id === id ? { ...i, folder: f?.label || folder, folderColor: f?.color || "#00ff88" } : i);
    saveIdeas(updated);
    setActiveIdea(prev => prev?.id === id ? { ...prev, folder: f?.label || folder, folderColor: f?.color || "#00ff88" } : prev);
    showToast(`Déplacée dans "${f?.label || folder}" ✓`);
  };

  const copyPrompt = (idea) => {
    navigator.clipboard.writeText(idea.prompt || "").then(() => {
      setCopiedId(idea.id); showToast("Prompt copié — colle dans Claude ✓");
      setTimeout(() => setCopiedId(null), 2500);
    });
  };

  const syncDot = { ok: "#00ff88", syncing: "#ffe600", err: "#ff4466", idle: "#334433" }[syncStatus];

  const filteredIdeas = ideas
    .filter(i => filterFolder === "toutes" || i.folder === filterFolder)
    .filter(i => filterStatus === "tous" || i.status === filterStatus)
    .filter(i => !searchVal || i.titre.toLowerCase().includes(searchVal.toLowerCase()) || i.concept.toLowerCase().includes(searchVal.toLowerCase()) || (i.tags||[]).some(t => t.toLowerCase().includes(searchVal.toLowerCase())));

  // ── Shared header ──
  const Header = ({ back, backLabel, backAction }) => (
    <div style={{ background: "rgba(3,10,5,0.97)", borderBottom: "1px solid #00ff8820", padding: "12px 16px", position: "sticky", top: 0, zIndex: 50, backdropFilter: "blur(12px)" }}>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "10px" }}>
          {back && (
            <button onClick={backAction || (() => setScreen("home"))} style={{ background: "transparent", border: "1px solid #00ff8822", borderRadius: "4px", color: "#00ff8866", padding: "6px 10px", cursor: "pointer", fontSize: "11px", letterSpacing: "0.1em", marginRight: "4px" }}>
              ← {backLabel || "RETOUR"}
            </button>
          )}
          {!back && <Logo size={32}/>}
          <div>
            <h1 style={{ margin: 0, fontSize: "17px", fontWeight: "700", letterSpacing: "0.06em", color: "#00ff88", textShadow: "0 0 20px #00ff88, 0 0 40px #00ff8866" }}>
              IDEA_BOX <span style={{ color: "#aaffcc", fontWeight: 400, textShadow: "0 0 15px #aaffcc77" }}>· MAT</span>
            </h1>
            <div style={{ display: "flex", gap: "12px", marginTop: "2px", fontSize: "10px", letterSpacing: "0.1em" }}>
              <span style={{ color: "#88bbaa" }}>{ideas.length} IDÉE{ideas.length !== 1 ? "S" : ""}</span>
              <span style={{ display: "flex", alignItems: "center", gap: "4px" }}>
                <span style={{ width: 6, height: 6, borderRadius: "50%", background: syncDot, display: "inline-block", boxShadow: `0 0 6px ${syncDot}`, animation: syncStatus === "syncing" ? "pulse 1s infinite" : "none" }}/>
                <span style={{ color: "#446655" }}>{syncStatus === "ok" ? "DRIVE ✓" : syncStatus === "syncing" ? "SYNC..." : syncStatus === "err" ? "LOCAL" : "—"}</span>
              </span>
              <span style={{ color: "#2a3a2a" }}>{time}</span>
            </div>
          </div>
        </div>
        <div style={{ display: "flex", gap: "6px" }}>
          <button onClick={() => setScreen("ideas")} style={{ background: screen === "ideas" ? "rgba(0,255,136,0.08)" : "transparent", border: `1px solid ${screen === "ideas" ? "#00ff8844" : "#00ff8818"}`, borderRadius: "4px", color: screen === "ideas" ? "#00ff88" : "#446655", padding: "7px 10px", cursor: "pointer", fontSize: "11px", letterSpacing: "0.08em" }}>
            LISTE
          </button>
          <button onClick={loadData} style={{ background: "transparent", border: "1px solid #00ff8818", borderRadius: "4px", color: "#00ff8844", padding: "7px 10px", cursor: "pointer", fontSize: "13px" }}>⟳</button>
        </div>
      </div>
    </div>
  );

  // ══════════════════════════════════════════════
  // SCREEN : HOME — Sélection dossier
  // ══════════════════════════════════════════════
  if (screen === "home") return (
    <div style={{ minHeight: "100vh", background: "#04080a", fontFamily: "'Courier New',monospace", color: "#c8ffd4", position: "relative", overflowX: "hidden" }}>
      <div style={{ position: "fixed", inset: 0, pointerEvents: "none", background: "repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,80,0.01) 3px,rgba(0,255,80,0.01) 4px)" }}/>
      <div style={{ position: "fixed", inset: 0, pointerEvents: "none", backgroundImage: "linear-gradient(rgba(0,255,80,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,80,0.018) 1px,transparent 1px)", backgroundSize: "44px 44px" }}/>
      <div style={{ position: "fixed", top: -80, left: "20%", width: 600, height: 350, background: "radial-gradient(ellipse,rgba(0,255,100,0.055) 0%,transparent 70%)", pointerEvents: "none" }}/>

      <Header />

      <div style={{ padding: "20px 16px", maxWidth: "700px", margin: "0 auto" }}>
        <div style={{ marginBottom: "24px", textAlign: "center" }}>
          <p style={{ margin: 0, fontSize: "11px", color: "#446655", letterSpacing: "0.2em" }}>
            CHOISIS LE TYPE DE PROJET — OU LAISSE L'IA DÉCIDER
          </p>
        </div>

        {/* Folder grid */}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "10px" }}>
          {FOLDERS.map((f, idx) => (
            <button
              key={f.id}
              onClick={() => { setSelectedFolder(f); setScreen("input"); }}
              style={{
                background: "rgba(2,14,8,0.9)",
                border: `1px solid ${f.color}33`,
                borderTop: `2px solid ${f.color}`,
                borderRadius: "6px",
                padding: "16px 14px",
                cursor: "pointer",
                textAlign: "left",
                transition: "all 0.2s",
                animation: `fadeIn 0.3s ease ${idx * 0.05}s both`,
                boxShadow: `0 0 20px ${f.color}08`,
                gridColumn: f.id === "libre" ? "1 / -1" : "auto",
              }}
              onMouseEnter={e => { e.currentTarget.style.background = `rgba(${f.color === "#00ff88" ? "0,255,136" : "2,14,8"},0.15)`; e.currentTarget.style.boxShadow = `0 0 30px ${f.color}22`; }}
              onMouseLeave={e => { e.currentTarget.style.background = "rgba(2,14,8,0.9)"; e.currentTarget.style.boxShadow = `0 0 20px ${f.color}08`; }}
            >
              <div style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "6px" }}>
                <span style={{ fontSize: f.id === "libre" ? "22px" : "20px" }}>{f.icon}</span>
                <span style={{
                  fontSize: f.id === "libre" ? "15px" : "13px",
                  fontWeight: "700",
                  color: f.color,
                  textShadow: `0 0 16px ${f.color}, 0 0 30px ${f.color}88`,
                  letterSpacing: "0.06em",
                }}>{f.label.toUpperCase()}</span>
              </div>
              <p style={{ margin: 0, fontSize: "11px", color: "#557766", letterSpacing: "0.04em" }}>{f.desc}</p>
              {f.id === "libre" && (
                <div style={{ marginTop: "8px", fontSize: "10px", color: f.color + "77", letterSpacing: "0.1em" }}>
                  ↳ L'IA ANALYSE TON IDÉE ET CHOISIT LE BON TYPE AUTOMATIQUEMENT
                </div>
              )}
            </button>
          ))}
        </div>

        {/* Voir les idées */}
        {ideas.length > 0 && (
          <button onClick={() => setScreen("ideas")} style={{
            width: "100%", marginTop: "16px",
            background: "transparent",
            border: "1px solid #00ff8820",
            borderRadius: "6px", color: "#446655",
            padding: "14px", cursor: "pointer",
            fontSize: "11px", letterSpacing: "0.12em",
            fontFamily: "inherit",
            transition: "all 0.2s",
          }}>
            VOIR MES {ideas.length} IDÉE{ideas.length !== 1 ? "S" : ""} ENREGISTRÉE{ideas.length !== 1 ? "S" : ""} →
          </button>
        )}
      </div>

      {toast && <Toast toast={toast}/>}
      <GlobalStyles/>
    </div>
  );

  // ══════════════════════════════════════════════
  // SCREEN : INPUT — Saisie de l'idée
  // ══════════════════════════════════════════════
  if (screen === "input") {
    const f = selectedFolder;
    return (
      <div style={{ minHeight: "100vh", background: "#04080a", fontFamily: "'Courier New',monospace", color: "#c8ffd4", position: "relative", overflowX: "hidden" }}>
        <div style={{ position: "fixed", inset: 0, pointerEvents: "none", background: "repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,80,0.01) 3px,rgba(0,255,80,0.01) 4px)" }}/>
        <div style={{ position: "fixed", top: -80, left: "20%", width: 600, height: 350, background: `radial-gradient(ellipse,${f.color}09 0%,transparent 70%)`, pointerEvents: "none" }}/>

        <Header back backLabel="ACCUEIL" backAction={() => setScreen("home")}/>

        <div style={{ padding: "20px 16px", maxWidth: "700px", margin: "0 auto" }}>

          {/* Selected folder badge */}
          <div style={{
            display: "inline-flex", alignItems: "center", gap: "10px",
            background: f.color + "12",
            border: `1px solid ${f.color}44`,
            borderRadius: "6px", padding: "10px 16px",
            marginBottom: "20px",
            boxShadow: `0 0 20px ${f.color}15`,
          }}>
            <span style={{ fontSize: "20px" }}>{f.icon}</span>
            <div>
              <div style={{ fontSize: "13px", fontWeight: "700", color: f.color, textShadow: `0 0 14px ${f.color}, 0 0 28px ${f.color}66`, letterSpacing: "0.08em" }}>
                {f.label.toUpperCase()}
              </div>
              <div style={{ fontSize: "10px", color: f.color + "77", letterSpacing: "0.06em", marginTop: "2px" }}>{f.desc}</div>
            </div>
            <button onClick={() => setScreen("home")} style={{ marginLeft: "8px", background: "transparent", border: "none", color: f.color + "55", cursor: "pointer", fontSize: "14px" }}>✕</button>
          </div>

          {/* Input card */}
          <div style={{ background: "rgba(0,18,10,0.85)", border: `1px solid ${f.color}22`, borderRadius: "6px", padding: "18px", position: "relative", boxShadow: `0 0 40px ${f.color}06` }}>
            <Corner pos="top-left"/><Corner pos="top-right"/><Corner pos="bottom-left"/><Corner pos="bottom-right"/>

            <div style={{ fontSize: "10px", color: f.color + "77", letterSpacing: "0.18em", marginBottom: "12px" }}>
              ▶ DÉCRIS TON IDÉE LIBREMENT
            </div>

            <textarea
              ref={inputRef}
              value={rawInput}
              onChange={e => setRawInput(e.target.value)}
              onKeyDown={e => { if (e.key === "Enter" && e.metaKey) generateIdea(); }}
              placeholder={`Décris ton idée de ${f.label.toLowerCase()}...`}
              style={{
                width: "100%", minHeight: "120px",
                background: "#020e06", border: `1px solid ${f.color}18`,
                borderRadius: "4px", color: "#b8f0c8",
                fontSize: "14px", fontFamily: "inherit", lineHeight: "1.7",
                padding: "12px 14px", resize: "vertical", outline: "none",
                boxSizing: "border-box", marginBottom: "14px",
              }}
            />

            <div style={{ display: "flex", gap: "8px" }}>
              <button onClick={isRecording ? stopRecording : startRecording} style={{
                background: isRecording ? "#ff446615" : "transparent",
                border: isRecording ? "1px solid #ff446644" : `1px solid ${f.color}22`,
                borderRadius: "4px", color: isRecording ? "#ff8899" : f.color + "66",
                padding: "10px 16px", cursor: "pointer", fontSize: "12px",
                display: "flex", alignItems: "center", gap: "6px",
                animation: isRecording ? "pulse 1s infinite" : "none",
              }}>
                🎤 <span style={{ letterSpacing: "0.06em" }}>{isRecording ? "STOP" : "VOCAL"}</span>
              </button>
              <button onClick={generateIdea} disabled={!rawInput.trim() || isProcessing} style={{
                flex: 1,
                background: rawInput.trim() && !isProcessing ? `linear-gradient(90deg,${f.color}18,${f.color}10)` : "transparent",
                border: rawInput.trim() && !isProcessing ? `1px solid ${f.color}` : `1px solid ${f.color}20`,
                borderRadius: "4px",
                color: rawInput.trim() && !isProcessing ? f.color : "#334433",
                padding: "10px", cursor: rawInput.trim() && !isProcessing ? "pointer" : "not-allowed",
                fontSize: "12px", fontWeight: "700", letterSpacing: "0.1em",
                textShadow: rawInput.trim() && !isProcessing ? `0 0 14px ${f.color}, 0 0 28px ${f.color}66` : "none",
                boxShadow: rawInput.trim() && !isProcessing ? `0 0 20px ${f.color}18` : "none",
                transition: "all 0.2s",
              }}>
                {isProcessing ? "⚡ GÉNÉRATION..." : `⚡ GÉNÉRER — ${f.label.toUpperCase()}`}
              </button>
            </div>
          </div>
        </div>

        {toast && <Toast toast={toast}/>}
        <GlobalStyles/>
      </div>
    );
  }

  // ══════════════════════════════════════════════
  // SCREEN : IDEA DETAIL
  // ══════════════════════════════════════════════
  if (screen === "idea_detail" && activeIdea) {
    const idea = ideas.find(i => i.id === activeIdea.id) || activeIdea;
    const fc = idea.folderColor || "#00ff88";
    const sc = STATUS_CONFIG[idea.status] || STATUS_CONFIG.idée;
    const pc = PRIORITY_CONFIG[idea.priority] || PRIORITY_CONFIG.moyenne;
    return (
      <div style={{ minHeight: "100vh", background: "#04080a", fontFamily: "'Courier New',monospace", color: "#c8ffd4", position: "relative", overflowX: "hidden" }}>
        <div style={{ position: "fixed", inset: 0, pointerEvents: "none", background: "repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,80,0.01) 3px,rgba(0,255,80,0.01) 4px)" }}/>
        <div style={{ position: "fixed", top: -80, left: "20%", width: 600, height: 350, background: `radial-gradient(ellipse,${fc}09 0%,transparent 70%)`, pointerEvents: "none" }}/>

        <Header back backLabel="IDÉES" backAction={() => setScreen("ideas")}/>

        <div style={{ padding: "20px 16px", maxWidth: "700px", margin: "0 auto" }}>

          {/* Title block */}
          <div style={{ background: "rgba(2,14,8,0.9)", border: `1px solid ${fc}33`, borderLeft: `3px solid ${fc}`, borderRadius: "6px", padding: "18px", marginBottom: "12px", boxShadow: `0 0 30px ${fc}12` }}>
            <div style={{ display: "flex", alignItems: "center", gap: "8px", flexWrap: "wrap", marginBottom: "8px" }}>
              <span style={{ fontSize: "20px", fontWeight: "700", color: fc, textShadow: `0 0 20px ${fc}, 0 0 40px ${fc}88, 0 0 70px ${fc}44`, letterSpacing: "0.06em" }}>
                {idea.titre}
              </span>
              <span style={{ fontSize: "9px", padding: "2px 8px", border: `1px solid ${sc.color}55`, borderRadius: "2px", color: sc.color, letterSpacing: "0.1em", textShadow: `0 0 8px ${sc.color}77` }}>{sc.label}</span>
              <span style={{ fontSize: "9px", color: pc.color }}>{pc.label}</span>
              <span style={{ fontSize: "9px", padding: "2px 8px", border: `1px solid ${fc}33`, borderRadius: "2px", color: fc + "aa", letterSpacing: "0.07em" }}>{idea.folder?.toUpperCase()}</span>
            </div>
            <p style={{ margin: "0 0 10px", fontSize: "13px", color: "#88bbaa", lineHeight: "1.6" }}>{idea.concept}</p>
            <div style={{ display: "flex", gap: "5px", flexWrap: "wrap" }}>
              {(idea.tags || []).map(tag => (
                <span key={tag} style={{ fontSize: "9px", padding: "2px 7px", border: "1px solid #00ff8818", borderRadius: "2px", color: "#557766" }}>#{tag}</span>
              ))}
            </div>
          </div>

          {/* Fonctionnalités */}
          <div style={{ background: "rgba(2,14,8,0.9)", border: "1px solid #00ff8815", borderRadius: "6px", padding: "16px", marginBottom: "12px" }}>
            <div style={{ fontSize: "10px", color: "#446655", letterSpacing: "0.15em", marginBottom: "10px" }}>FONCTIONNALITÉS</div>
            {(idea.fonctionnalites || []).map((f, i) => (
              <div key={i} style={{ display: "flex", gap: "10px", padding: "6px 0", borderBottom: i < idea.fonctionnalites.length - 1 ? "1px solid #00ff8810" : "none", fontSize: "13px", color: "#99ccaa" }}>
                <span style={{ color: fc, flexShrink: 0, textShadow: `0 0 6px ${fc}77` }}>▸</span>{f}
              </div>
            ))}
          </div>

          {/* Prompt */}
          {idea.prompt && (
            <div style={{ background: "#020d0a", border: "1px solid #00ccff22", borderRadius: "6px", padding: "16px", marginBottom: "12px" }}>
              <div style={{ fontSize: "10px", color: "#00ccff88", letterSpacing: "0.15em", marginBottom: "10px" }}>⚡ PROMPT POUR CLAUDE</div>
              <p style={{ margin: "0 0 14px", fontSize: "12px", color: "#88ccdd", lineHeight: "1.7" }}>{idea.prompt}</p>
              <button onClick={() => copyPrompt(idea)} style={{
                width: "100%",
                background: copiedId === idea.id ? "#00ff8815" : "#00ccff0d",
                border: `1px solid ${copiedId === idea.id ? "#00ff8844" : "#00ccff33"}`,
                borderRadius: "4px", color: copiedId === idea.id ? "#00ff88" : "#00ccff",
                padding: "10px", cursor: "pointer", fontSize: "12px", fontWeight: "700", letterSpacing: "0.08em",
                textShadow: copiedId === idea.id ? "0 0 10px #00ff88" : "0 0 10px #00ccff55",
                transition: "all 0.2s",
              }}>
                {copiedId === idea.id ? "✓ COPIÉ — COLLE DANS CLAUDE !" : "📋 COPIER LE PROMPT"}
              </button>
            </div>
          )}

          {/* Statut */}
          <div style={{ background: "rgba(2,14,8,0.9)", border: "1px solid #00ff8815", borderRadius: "6px", padding: "14px", marginBottom: "12px" }}>
            <div style={{ fontSize: "10px", color: "#446655", letterSpacing: "0.15em", marginBottom: "10px" }}>CHANGER LE STATUT</div>
            <div style={{ display: "flex", gap: "8px" }}>
              {Object.entries(STATUS_CONFIG).map(([k, v]) => (
                <button key={k} onClick={() => updateStatus(idea.id, k)} style={{
                  flex: 1,
                  background: idea.status === k ? v.color + "18" : "transparent",
                  border: `1px solid ${idea.status === k ? v.color + "77" : "#00ff8818"}`,
                  borderRadius: "4px", color: idea.status === k ? v.color : "#446655",
                  padding: "8px", cursor: "pointer", fontSize: "10px", letterSpacing: "0.08em",
                  textShadow: idea.status === k ? `0 0 8px ${v.color}` : "none",
                  transition: "all 0.15s",
                }}>{v.label}</button>
              ))}
            </div>
          </div>

          {/* Déplacer */}
          <div style={{ background: "rgba(2,14,8,0.9)", border: "1px solid #00ff8815", borderRadius: "6px", padding: "14px", marginBottom: "12px" }}>
            <div style={{ fontSize: "10px", color: "#446655", letterSpacing: "0.15em", marginBottom: "10px" }}>DÉPLACER DANS UN AUTRE DOSSIER</div>
            <div style={{ display: "flex", gap: "6px", flexWrap: "wrap" }}>
              {FOLDERS.filter(f => f.label !== idea.folder && f.id !== "libre").map(f => (
                <button key={f.id} onClick={() => moveIdea(idea.id, f.label)} style={{
                  background: "transparent", border: `1px solid ${f.color}33`,
                  borderRadius: "3px", color: f.color + "88",
                  padding: "5px 10px", cursor: "pointer", fontSize: "10px", letterSpacing: "0.05em",
                  transition: "all 0.15s",
                }}>{f.icon} {f.label}</button>
              ))}
            </div>
          </div>

          {/* Idée brute */}
          <div style={{ background: "rgba(2,14,8,0.9)", border: "1px solid #00ff8810", borderRadius: "6px", padding: "14px", marginBottom: "16px" }}>
            <div style={{ fontSize: "10px", color: "#334433", letterSpacing: "0.15em", marginBottom: "6px" }}>IDÉE ORIGINALE</div>
            <p style={{ margin: 0, fontSize: "11px", color: "#446655", fontStyle: "italic", lineHeight: "1.6" }}>{idea.raw}</p>
            <div style={{ marginTop: "8px", fontSize: "9px", color: "#223322", textAlign: "right", letterSpacing: "0.1em" }}>CRÉÉ LE {idea.date}</div>
          </div>

          {/* Nouvelle idée + Supprimer */}
          <div style={{ display: "flex", gap: "8px" }}>
            <button onClick={() => setScreen("home")} style={{
              flex: 1, background: "rgba(0,255,136,0.06)", border: "1px solid #00ff8833",
              borderRadius: "4px", color: "#00ff88", padding: "12px", cursor: "pointer",
              fontSize: "12px", fontWeight: "700", letterSpacing: "0.08em",
              textShadow: "0 0 10px #00ff88", transition: "all 0.2s",
            }}>+ NOUVELLE IDÉE</button>
            {deleteConfirm === idea.id ? (
              <>
                <button onClick={() => deleteIdea(idea.id)} style={{ background: "#ff446618", border: "1px solid #ff446644", borderRadius: "4px", color: "#ff7788", padding: "12px 16px", cursor: "pointer", fontSize: "11px", letterSpacing: "0.06em" }}>CONFIRMER 🗑</button>
                <button onClick={() => setDeleteConfirm(null)} style={{ background: "transparent", border: "1px solid #00ff8818", borderRadius: "4px", color: "#446655", padding: "12px", cursor: "pointer", fontSize: "11px" }}>✕</button>
              </>
            ) : (
              <button onClick={() => setDeleteConfirm(idea.id)} style={{ background: "transparent", border: "1px solid #ff446620", borderRadius: "4px", color: "#ff446555", padding: "12px 14px", cursor: "pointer", fontSize: "14px" }}>🗑</button>
            )}
          </div>
        </div>

        {toast && <Toast toast={toast}/>}
        <GlobalStyles/>
      </div>
    );
  }

  // ══════════════════════════════════════════════
  // SCREEN : IDEAS LIST
  // ══════════════════════════════════════════════
  return (
    <div style={{ minHeight: "100vh", background: "#04080a", fontFamily: "'Courier New',monospace", color: "#c8ffd4", position: "relative", overflowX: "hidden" }}>
      <div style={{ position: "fixed", inset: 0, pointerEvents: "none", background: "repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,80,0.01) 3px,rgba(0,255,80,0.01) 4px)" }}/>
      <div style={{ position: "fixed", inset: 0, pointerEvents: "none", backgroundImage: "linear-gradient(rgba(0,255,80,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,80,0.018) 1px,transparent 1px)", backgroundSize: "44px 44px" }}/>

      <Header/>

      <div style={{ padding: "16px", maxWidth: "700px", margin: "0 auto" }}>

        {/* Search */}
        <div style={{ background: "#020e06", border: "1px solid #00ff8820", borderRadius: "4px", padding: "10px 14px", display: "flex", gap: "10px", alignItems: "center", marginBottom: "12px" }}>
          <span style={{ color: "#446655" }}>⌕</span>
          <input value={searchVal} onChange={e => setSearchVal(e.target.value)}
            placeholder="Rechercher une idée..."
            style={{ background: "transparent", border: "none", outline: "none", color: "#aaccbb", fontSize: "13px", fontFamily: "inherit", width: "100%" }}
          />
        </div>

        {/* Filters */}
        <div style={{ display: "flex", gap: "6px", flexWrap: "wrap", marginBottom: "16px" }}>
          <button onClick={() => setFilterFolder("toutes")} style={{ background: filterFolder === "toutes" ? "rgba(0,255,136,0.08)" : "transparent", border: `1px solid ${filterFolder === "toutes" ? "#00ff8844" : "#00ff8815"}`, borderRadius: "3px", color: filterFolder === "toutes" ? "#00ff88" : "#446655", padding: "5px 11px", cursor: "pointer", fontSize: "10px", letterSpacing: "0.08em" }}>
            TOUTES ({ideas.length})
          </button>
          {FOLDERS.filter(f => f.id !== "libre" && ideas.some(i => i.folder === f.label)).map(f => (
            <button key={f.id} onClick={() => setFilterFolder(f.label)} style={{ background: filterFolder === f.label ? f.color + "18" : "transparent", border: `1px solid ${filterFolder === f.label ? f.color + "55" : "#00ff8815"}`, borderRadius: "3px", color: filterFolder === f.label ? f.color : "#446655", padding: "5px 11px", cursor: "pointer", fontSize: "10px", letterSpacing: "0.06em", textShadow: filterFolder === f.label ? `0 0 8px ${f.color}` : "none" }}>
              {f.icon} {f.label} ({ideas.filter(i => i.folder === f.label).length})
            </button>
          ))}
        </div>

        {/* Empty */}
        {filteredIdeas.length === 0 && (
          <div style={{ textAlign: "center", padding: "60px 20px" }}>
            <div style={{ fontSize: "36px", marginBottom: "12px", opacity: 0.3 }}>💭</div>
            <p style={{ fontSize: "11px", color: "#334433", letterSpacing: "0.12em" }}>{ideas.length === 0 ? "AUCUNE IDÉE — CLIQUE SUR + NOUVELLE IDÉE" : "AUCUNE IDÉE DANS CE FILTRE"}</p>
            <button onClick={() => setScreen("home")} style={{ marginTop: "16px", background: "rgba(0,255,136,0.06)", border: "1px solid #00ff8833", borderRadius: "4px", color: "#00ff88", padding: "10px 20px", cursor: "pointer", fontSize: "11px", letterSpacing: "0.1em", fontFamily: "inherit" }}>+ NOUVELLE IDÉE</button>
          </div>
        )}

        {/* List */}
        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
          {filteredIdeas.map((idea, idx) => {
            const fc = idea.folderColor || "#00ff88";
            const sc = STATUS_CONFIG[idea.status] || STATUS_CONFIG.idée;
            const pc = PRIORITY_CONFIG[idea.priority] || PRIORITY_CONFIG.moyenne;
            return (
              <div key={idea.id}
                onMouseEnter={() => setGlitchId(idea.id)}
                onMouseLeave={() => setGlitchId(null)}
                onClick={() => { setActiveIdea(idea); setScreen("idea_detail"); }}
                style={{
                  background: "rgba(2,14,8,0.9)", border: `1px solid ${fc}22`,
                  borderLeft: `3px solid ${fc}`, borderRadius: "5px",
                  padding: "13px 15px", cursor: "pointer",
                  transition: "all 0.2s",
                  animation: `fadeIn 0.3s ease ${idx * 0.05}s both`,
                  boxShadow: `0 0 16px ${fc}08`,
                }}>
                <div style={{ display: "flex", alignItems: "flex-start", gap: "10px" }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: "flex", alignItems: "center", gap: "8px", flexWrap: "wrap", marginBottom: "5px" }}>
                      <span style={{ fontSize: "15px", fontWeight: "700", color: fc, letterSpacing: "0.05em", textShadow: `0 0 18px ${fc}, 0 0 35px ${fc}88` }}>
                        <GlitchText text={idea.titre} active={glitchId === idea.id}/>
                      </span>
                      <span style={{ fontSize: "9px", padding: "2px 6px", border: `1px solid ${sc.color}44`, borderRadius: "2px", color: sc.color, textShadow: `0 0 6px ${sc.color}66` }}>{sc.label}</span>
                      <span style={{ fontSize: "9px", color: pc.color }}>{pc.label}</span>
                    </div>
                    <p style={{ margin: 0, fontSize: "12px", color: "#88bbaa", lineHeight: "1.5", display: "-webkit-box", WebkitLineClamp: 2, WebkitBoxOrient: "vertical", overflow: "hidden" }}>{idea.concept}</p>
                    {(idea.tags || []).length > 0 && (
                      <div style={{ display: "flex", gap: "4px", flexWrap: "wrap", marginTop: "6px" }}>
                        {(idea.tags || []).map(tag => (
                          <span key={tag} style={{ fontSize: "9px", padding: "1px 6px", border: "1px solid #00ff8815", borderRadius: "2px", color: "#446655" }}>#{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div style={{ display: "flex", flexDirection: "column", alignItems: "flex-end", gap: "5px", flexShrink: 0 }}>
                    <span style={{ fontSize: "9px", padding: "2px 7px", border: `1px solid ${fc}33`, borderRadius: "2px", color: fc + "99" }}>{idea.folder?.toUpperCase()}</span>
                    <span style={{ color: "#334433", fontSize: "11px" }}>→</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        {ideas.length > 0 && (
          <button onClick={() => setScreen("home")} style={{ width: "100%", marginTop: "16px", background: "rgba(0,255,136,0.05)", border: "1px solid #00ff8822", borderRadius: "6px", color: "#00ff8866", padding: "14px", cursor: "pointer", fontSize: "11px", letterSpacing: "0.12em", fontFamily: "inherit" }}>
            + NOUVELLE IDÉE
          </button>
        )}
      </div>

      {toast && <Toast toast={toast}/>}
      <GlobalStyles/>
    </div>
  );
}

function Toast({ toast }) {
  return (
    <div style={{
      position: "fixed", bottom: "24px", left: "50%", transform: "translateX(-50%)",
      background: toast.type === "err" ? "#1a0505" : "#030f06",
      border: `1px solid ${toast.type === "err" ? "#ff446644" : "#00ff8833"}`,
      color: toast.type === "err" ? "#ff8899" : "#00ff88",
      padding: "11px 22px", borderRadius: "4px",
      fontSize: "12px", letterSpacing: "0.08em", zIndex: 100,
      boxShadow: "0 8px 32px rgba(0,0,0,0.4)",
      animation: "fadeUp 0.2s ease", whiteSpace: "nowrap",
      textShadow: toast.type === "err" ? "0 0 10px #ff4466" : "0 0 10px #00ff88",
    }}>{toast.msg}</div>
  );
}

function GlobalStyles() {
  return (
    <style>{`
      @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
      @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
      @keyframes fadeUp{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
      textarea:focus{border-color:#00ff8833!important;}
      input:focus{outline:none;}
      *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
      ::-webkit-scrollbar{width:4px;background:#020e06;}
      ::-webkit-scrollbar-thumb{background:#00ff8818;border-radius:2px;}
    `}</style>
  );
}
